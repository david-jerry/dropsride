{
  "extends": [
    "development"
  ],
  "hints": {
    "manifest-file-extension": "off",
    "apple-touch-icons": "off",
    "highest-available-document-mode": "off",
    "meta-viewport": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_ff <= 105",
    "not firefox <= 105",
    "not ios_saf <= 14.8",
    "not opera <= 91"
  ]
}